# Copie este arquivo para ".env" e preencha com seus valores.
# O .env é ignorado pelo git (nunca comite suas credenciais).

# Connection string do MongoDB Atlas (Database > Connect > Drivers).
# Troque <user>, <senha> e o host pelos seus. A senha precisa estar
# URL-encoded se tiver caracteres especiais (@ : / etc).
MONGO_URI=mongodb+srv://<user>:<senha>@<cluster>.xxxxx.mongodb.net/?retryWrites=true&w=majority

# Opcionais (têm defaults no código):
# PAGE_LIMIT=10
# PRICE_CEILING=300000
